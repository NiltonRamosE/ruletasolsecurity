<?xml version="1.0" encoding="utf-8"?>
<!--
    Indicador tipo "pin": un círculo superior con una punta triangular inferior
    que señala exactamente el sector de la ruleta. Más pequeño y sobrio que
    una flecha genérica.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="28dp"
    android:viewportWidth="24"
    android:viewportHeight="28">

    <!-- Punta triangular (apunta hacia abajo, hacia la ruleta) -->
    <path
        android:fillColor="#060A51"
        android:pathData="M12,28 L4,14 L20,14 Z" />

    <!-- Círculo superior -->
    <path
        android:fillColor="#060A51"
        android:pathData="M12,0 C17.5,0 22,4.5 22,10 C22,15.5 12,15.5 12,15.5 C12,15.5 2,15.5 2,10 C2,4.5 6.5,0 12,0 Z" />

    <!-- Punto central amarillo (acento de marca) -->
    <path
        android:fillColor="#FAB323"
        android:pathData="M12,5 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" />

</vector>