<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    tools:context=".MainActivity">

    <!-- ============ FORMAS DECORATIVAS DE FONDO ============ -->
    <!-- Círculo amarillo grande, esquina superior derecha, parcialmente fuera de pantalla -->
    <View
        android:id="@+id/decorTopCircle"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginTop="-90dp"
        android:layout_marginEnd="-70dp"
        android:background="@drawable/bg_decorative_circle_yellow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Círculo azul mediano, esquina superior izquierda -->
    <View
        android:id="@+id/decorTopSmallCircle"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="-40dp"
        android:background="@drawable/bg_decorative_circle_blue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Círculo azul grande, esquina inferior izquierda -->
    <View
        android:id="@+id/decorBottomCircle"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginBottom="-110dp"
        android:layout_marginStart="-90dp"
        android:background="@drawable/bg_decorative_circle_blue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Círculo amarillo pequeño, esquina inferior derecha -->
    <View
        android:id="@+id/decorBottomSmallCircle"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginBottom="40dp"
        android:layout_marginEnd="-24dp"
        android:background="@drawable/bg_decorative_circle_yellow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ============ CONTENIDO PRINCIPAL ============ -->

    <!-- Badge superior: le da un aire "premium" / oficial a la app -->
    <TextView
        android:id="@+id/tvBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:background="@drawable/bg_badge_pill"
        android:text="@string/badge_label"
        android:textColor="@color/badge_text"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Título tratado como logotipo de dos líneas y dos tonos -->
    <TextView
        android:id="@+id/tvTitleLine1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/title_line_1"
        android:textColor="@color/text_title"
        android:textSize="34sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.02"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBadge" />

    <TextView
        android:id="@+id/tvTitleLine2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-6dp"
        android:text="@string/title_line_2"
        android:textColor="@color/brand_yellow_dark"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitleLine1" />

    <!-- Pequeña línea decorativa bajo el título -->
    <View
        android:id="@+id/titleDivider"
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_badge_pill"
        android:backgroundTint="@color/brand_yellow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitleLine2" />

    <!-- Subtítulo / tagline -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/subtitle_main"
        android:textColor="@color/text_subtitle"
        android:textSize="13sp"
        android:letterSpacing="0.08"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleDivider" />

    <!-- Medalla circular que contiene el logo, con sombra y doble anillo de marca -->
    <FrameLayout
        android:id="@+id/logoMedallion"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_logo_medallion"
        android:elevation="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnComenzar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintVertical_bias="0.5">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:contentDescription="@string/logo_content_description"
            android:scaleType="centerInside"
            android:src="@drawable/sol_security_logo_2" />

    </FrameLayout>

    <!-- Botón COMENZAR: forma "pill", degradado, ícono + texto -->
    <LinearLayout
        android:id="@+id/btnComenzar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginBottom="56dp"
        android:background="@drawable/bg_button_comenzar_ripple"
        android:clickable="true"
        android:focusable="true"
        android:elevation="10dp"
        android:stateListAnimator="@null"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_play_arrow" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_comenzar"
            android:textColor="@color/button_text"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>