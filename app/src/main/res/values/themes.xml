<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema base de la app, heredado de Material Components -->
    <style name="Theme.RuletaSolSecurity" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Colores primarios de marca -->
        <item name="colorPrimary">@color/brand_dark_blue</item>
        <item name="colorPrimaryVariant">@color/brand_dark_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Color de acento / secundario -->
        <item name="colorSecondary">@color/brand_yellow</item>
        <item name="colorSecondaryVariant">@color/brand_yellow</item>
        <item name="colorOnSecondary">@color/brand_dark_blue</item>
        <!-- Barra de estado -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/background_primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <!-- Fondo por defecto de las ventanas -->
        <item name="android:windowBackground">@color/background_primary</item>
    </style>
</resources>